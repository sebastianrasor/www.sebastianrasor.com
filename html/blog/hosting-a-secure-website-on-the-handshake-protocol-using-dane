                     IN  NS     rasor.
                     IN  SOA    rasor. sebastian.rasor. (
                                2021020401      ; serial
                                1h              ; refresh
                                30m             ; retry
                                7d              ; expire
                                1h )            ; negative
                     IN  MX     0 rasor.
                     IN  TXT    "v=spf1 mx -all"
                     IN  SSHFP  1 1 159d8df12f7d7ca6506cc33060fa7195013c47fd
